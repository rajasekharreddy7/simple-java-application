pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/rajasekharreddy7/simple-java-application.git'
            }
        }
        stage('Build') {
            steps {
                sh 'mvn clean install package'
            }
        }
              stage('Test'){
            steps{
            sh 'mvn test'
        }
        }
    stage('Upload to JFrog') {
        steps {
            withCredentials([usernamePassword(
                credentialsId: 'jfrog',
                usernameVariable: 'admin',
                passwordVariable: 'Jfrog@89')]) {
            script {
                def jarFile = sh(script: "ls target/*.jar | head -1", returnStdout: true).trim()
                def jarName = jarFile.tokenize('/').last()
                echo "JAR file found: ${jarFile}"
                echo "Uploading as: ${jarName}"
                sh '''
                    curl -u ${JFROG_USER}:${JFROG_PASSWORD} \
                         -X PUT \
                         -T ${jarFile} \
                         "https://http://18.60.45.252:8082//artifactory/firstone/simple-java-application/${BUILD_NUMBER}/${jarName}"
                '''
            }
        }
    }
}
        stage('Deploy') {
            steps {
                sh '''
                    cp target/*.jar app.jar
                    # Find process on 8083 (matching your java command)
                    PID=$(lsof -t -i:8083) || true
                    if [ ! -z "$PID" ]; then
                        kill -9 $PID
                    fi
                    # Run in background so Jenkins doesn't hang
                    nohup java -jar app.jar --server.port=8083 > app.log 2>&1 &
                '''
            }
        }
    }
}
