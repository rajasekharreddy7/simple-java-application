pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url:'https://github.com/rajasekharreddy7/simple-java-application.git'
            }
        }
        stage('Build') {
            steps {
                sh 'mvn clean install package'
            }
        }
        stage('Test'){
            steps {
                sh 'mvn test'
            }
        }
        stage('Deploy') {
            steps {
                sh'''
                cp target/*.jar app.jar
                 PID=$(lsof -t -i:8081) || true
                if [ ! -z "$PID" ]; then
                     kill -9 $PID
                fi
                java -jar app.jar --server.port=8083
                '''
            }
        }
    }
}
